# Local Docker development settings.
# Copy this file to .env before starting docker compose.

POSTGRES_DB=plant_monitor
POSTGRES_USER=plant_monitor
POSTGRES_PASSWORD=plant_monitor_dev_password
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@plant-monitor.local
PGADMIN_DEFAULT_PASSWORD=plant_monitor_admin
PGADMIN_PORT=5050

# Future server-side image storage path for the Node app.
UPLOAD_DIR=./server-uploads
